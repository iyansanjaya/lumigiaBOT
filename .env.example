# ============================================
# LumigiaBOT - Environment Configuration
# Copy this file to .env and fill in real values.
# ============================================

# Discord bot and OAuth (required)
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# Dashboard auth (required)
# Auth.js v5 uses AUTH_SECRET, not NEXTAUTH_SECRET.
AUTH_SECRET=generate_a_random_secret_here
AUTH_TRUST_HOST=true
AUTH_URL=http://localhost:3412

# Database
DATABASE_PATH=./data/lumigiabot.db

# Bot runtime
DEFAULT_LANGUAGE=id
BOT_OWNER_ID=your_discord_user_id_here
LOG_LEVEL=INFO

# Optional integrations
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Optional operations
# Set to true only when you want /api/health to expose env/database details in production.
HEALTHCHECK_DETAILS=false
